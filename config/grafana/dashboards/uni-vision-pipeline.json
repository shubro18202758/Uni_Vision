{
  "annotations": {
    "list": []
  },
  "description": "Uni_Vision Detection Pipeline — Real-time monitoring dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pipeline Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(uv_frames_ingested_total[5m])",
          "legendFormat": "{{camera_id}} ingested"
        }
      ],
      "title": "Frame Ingestion Rate (per sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(uv_detections_total[5m])",
          "legendFormat": "{{camera_id}} detections"
        }
      ],
      "title": "Detection Rate (per sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(uv_frames_deduplicated_total[5m])",
          "legendFormat": "{{camera_id}} deduplicated"
        },
        {
          "expr": "rate(uv_frames_dropped_total[5m])",
          "legendFormat": "{{camera_id}} dropped"
        }
      ],
      "title": "Frame Dedup & Drop Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "OCR Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(uv_ocr_success_total[5m])) / sum(rate(uv_ocr_requests_total[5m]))",
          "legendFormat": "OCR Accuracy"
        }
      ],
      "title": "OCR Accuracy Rate",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(uv_ocr_requests_total[5m])",
          "legendFormat": "{{engine}} requests"
        },
        {
          "expr": "rate(uv_ocr_success_total[5m])",
          "legendFormat": "{{engine}} success"
        }
      ],
      "title": "OCR Requests by Engine",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(uv_ocr_confidence_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_ocr_confidence_bucket[5m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(uv_ocr_confidence_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "OCR Confidence Percentiles",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Pipeline Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(uv_pipeline_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_pipeline_latency_seconds_bucket[5m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(uv_pipeline_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "End-to-End Pipeline Latency (S0→S8)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S2_vehicle_detect\"}[5m]))",
          "legendFormat": "S2 Vehicle Detect"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S3_plate_detect\"}[5m]))",
          "legendFormat": "S3 Plate Detect"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S4_crop\"}[5m]))",
          "legendFormat": "S4 Crop"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S5_straighten\"}[5m]))",
          "legendFormat": "S5 Straighten"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S6_enhance\"}[5m]))",
          "legendFormat": "S6 Enhance"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S7_ocr\"}[5m]))",
          "legendFormat": "S7 OCR"
        },
        {
          "expr": "histogram_quantile(0.90, rate(uv_stage_latency_seconds_bucket{stage=\"S8_dispatch\"}[5m]))",
          "legendFormat": "S8 Dispatch"
        }
      ],
      "title": "Per-Stage Latency (p90)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "GPU & Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decmbytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "expr": "uv_vram_usage_bytes / 1024 / 1024",
          "legendFormat": "{{region}}"
        }
      ],
      "title": "VRAM Usage by Region (MB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 10,
      "targets": [
        {
          "expr": "uv_inference_queue_depth",
          "legendFormat": "Queue Depth"
        }
      ],
      "title": "Inference Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "uv_stream_status",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "title": "Camera Stream Status",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "Dispatch & Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "id": 12,
      "targets": [
        {
          "expr": "rate(uv_dispatch_success_total[5m])",
          "legendFormat": "Success"
        },
        {
          "expr": "rate(uv_dispatch_errors_total[5m])",
          "legendFormat": "{{target}} Errors"
        }
      ],
      "title": "Dispatch Rate (Success vs Errors)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "id": 13,
      "targets": [
        {
          "expr": "rate(uv_detections_deduplicated_total[5m])",
          "legendFormat": "Deduplicated"
        }
      ],
      "title": "Detection Deduplication Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "id": 14,
      "targets": [
        {
          "expr": "rate(uv_ocr_fallback_total[5m])",
          "legendFormat": "OCR Fallbacks"
        }
      ],
      "title": "OCR Fallback Rate",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["uni-vision", "detection", "pipeline"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Uni_Vision Pipeline",
  "uid": "uni-vision-pipeline",
  "version": 1
}
