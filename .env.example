# ─── Uni_Vision Environment Configuration ───
# Copy to .env and fill in values. Never commit .env to version control.

# ─── Hardware ───
UV_DEVICE=cuda                          # cuda | cpu
UV_CUDA_DEVICE_INDEX=0
UV_VRAM_CEILING_MB=8192
UV_VRAM_SAFETY_MARGIN_MB=256
UV_VRAM_POLL_INTERVAL_MS=500

# ─── Ollama (LLM Runtime) ───
UV_OLLAMA_BASE_URL=http://localhost:11434
UV_OLLAMA_MODEL=qwen3.5:9b-q4_K_M
UV_OLLAMA_TIMEOUT_S=5
UV_OLLAMA_NUM_CTX=4096
UV_OLLAMA_TEMPERATURE=0.1
UV_OLLAMA_TOP_P=0.9
UV_OLLAMA_TOP_K=20
UV_OLLAMA_REPEAT_PENALTY=1.15
UV_OLLAMA_REPEAT_LAST_N=128
UV_OLLAMA_NUM_PREDICT=256
UV_OLLAMA_NUM_BATCH=256
UV_OLLAMA_NUM_GPU=-1                    # -1 = offload all layers
UV_OLLAMA_SEED=42

# ─── Profiling ───
UV_PROFILING_ENABLED=true
UV_PROFILING_DEVICE_INDEX=0
UV_PROFILING_HISTORY_SIZE=512
UV_PROFILING_VALIDATE_VRAM_BUDGET_ON_START=true

# ─── Database (PostgreSQL) ───
UV_POSTGRES_DSN=postgresql://uni_vision:changeme@localhost:5432/uni_vision
UV_POSTGRES_POOL_MIN=2
UV_POSTGRES_POOL_MAX=8

# ─── Object Storage (S3-compatible) ───
UV_S3_ENDPOINT=http://localhost:9000
UV_S3_BUCKET=uni-vision-images
UV_S3_ACCESS_KEY=minioadmin
UV_S3_SECRET_KEY=minioadmin
UV_S3_REGION=us-east-1

# ─── Redis ───
UV_REDIS_URL=redis://localhost:6379/0

# ─── API Server ───
UV_API_HOST=0.0.0.0
UV_API_PORT=8000
UV_API_WORKERS=1
UV_API_API_KEYS=                         # comma-separated keys; empty = auth disabled
UV_API_RATE_LIMIT_RPM=120                # requests/min per IP; 0 = disabled
UV_API_CORS_ORIGINS=                     # comma-separated origins; empty = allow all (dev)

# ─── Logging ───
UV_LOG_LEVEL=INFO
UV_LOG_FORMAT=json                      # json | console

# ─── Visualizer ───
UV_VISUALIZER_ENABLED=false

# ─── Pipeline Tuning ───
UV_STREAM_QUEUE_MAXSIZE=50
UV_INFERENCE_QUEUE_MAXSIZE=10
UV_INFERENCE_QUEUE_HIGH_WATER=8
UV_INFERENCE_QUEUE_LOW_WATER=3
UV_DEDUP_WINDOW_S=10
